{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://byte-engine.dev/schemas/besl.bead.schema.json",
  "title": "Byte Engine standalone BESL shader settings",
  "description": "Pipeline-stage metadata for an adjacent standalone .besl source file.",
  "oneOf": [
    { "$ref": "#/$defs/raster" },
    { "$ref": "#/$defs/compute" },
    { "$ref": "#/$defs/task" },
    { "$ref": "#/$defs/mesh" }
  ],
  "$defs": {
    "positiveInteger": { "type": "integer", "minimum": 1, "maximum": 4294967295 },
    "workgroup": {
      "description": "Positive workgroup dimensions. Omitted width, height, or depth dimensions default to 1.",
      "oneOf": [
        {
          "type": "array",
          "prefixItems": [
            { "$ref": "#/$defs/positiveInteger" },
            { "$ref": "#/$defs/positiveInteger" },
            { "$ref": "#/$defs/positiveInteger" }
          ],
          "items": false
        },
        {
          "type": "object",
          "properties": {
            "width": { "$ref": "#/$defs/positiveInteger" },
            "height": { "$ref": "#/$defs/positiveInteger" },
            "depth": { "$ref": "#/$defs/positiveInteger" }
          },
          "additionalProperties": false
        }
      ]
    },
    "raster": {
      "type": "object",
      "properties": { "$schema": { "type": "string" }, "stage": { "enum": ["Vertex", "Fragment"] } },
      "required": ["stage"],
      "additionalProperties": false
    },
    "compute": {
      "type": "object",
      "properties": { "$schema": { "type": "string" }, "stage": { "const": "Compute" }, "workgroup": { "$ref": "#/$defs/workgroup" } },
      "required": ["stage"],
      "additionalProperties": false
    },
    "task": {
      "type": "object",
      "properties": {
		"$schema": { "type": "string" },
        "stage": { "const": "Task" },
        "workgroup": { "$ref": "#/$defs/workgroup" },
        "maximum_mesh_threadgroups": { "$ref": "#/$defs/positiveInteger" }
      },
      "required": ["stage", "maximum_mesh_threadgroups"],
      "additionalProperties": false
    },
    "mesh": {
      "type": "object",
      "properties": {
		"$schema": { "type": "string" },
        "stage": { "const": "Mesh" },
        "workgroup": { "$ref": "#/$defs/workgroup" },
        "maximum_vertices": { "$ref": "#/$defs/positiveInteger" },
        "maximum_primitives": { "$ref": "#/$defs/positiveInteger" }
      },
      "required": ["stage", "maximum_vertices", "maximum_primitives"],
      "additionalProperties": false
    }
  }
}
